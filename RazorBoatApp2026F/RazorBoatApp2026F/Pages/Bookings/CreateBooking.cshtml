@page
@model RazorBoatApp2026F.Pages.Bookings.CreateBookingModel
@{
}


<h1>Create Booking</h1>
<form method="post">

    <div class="form-group">
        <label>Boat id</label> : @Model.TheBoatToBeBooked.Id <br />
        <label>Boat sailnumber</label> : @Model.TheBoatToBeBooked.SailNumber <br />
        <label>Boat model</label> : @Model.TheBoatToBeBooked.Model <br />
        <label>Boat year of construction</label> : @Model.TheBoatToBeBooked.YearOfConstruction <br />

    </div>
    <div class="form-group">

        <label asp-for="@Model.Id" class="control-label">ID</label>
        <input asp-for="@Model.Id" class="form-control" />
    </div>
    <div class="form-group">
       
        <label asp-for="@Model.PhoneNumber" class="control-label">Phone number</label>
         <input asp-for="@Model.PhoneNumber" class="form-control" />
    </div>

    <div class="form-group">

        <label asp-for="@Model.StartDate" class="control-label"></label>
        <input asp-for="@Model.StartDate" class="form-control" />
    </div>

    <div class="form-group">

        <label asp-for="@Model.EndDate" class="control-label"></label>
        <input asp-for="@Model.EndDate" class="form-control" />
    </div>
    <div class="form-group">

        <label asp-for="@Model.Destination" class="control-label"></label>
        <input asp-for="@Model.Destination" class="form-control" />
    </div>
 <div class="form-group">
        <input type="submit" value="Create booking" class="btn btn-primary" />
    </div>
</form>